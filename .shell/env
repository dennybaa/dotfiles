#!/bin/sh
# Environment file is loaded in .profile and in .bashrc/.zshrc which makes it
# a right place for tools which should be loaded for non-interactive shells.
#
. ~/.shell/lib

# Append custom PATHS
_dot_append_paths \
    "${HOME}/.local/bin" \
    "${HOME}/.local/scripts"


# Code for none interactive shells (load tools which update PATH)
case $- in
    *i*);;
      *)
        # Don't rely on ~/.local/share/mise/shims in PATH, but rather set statically the global env
        eval $(cd $HOME && mise env)
        ;;
esac


# Use Podman instead of Docker if it is available
if podman -v >/dev/null 2>/dev/null; then
    export DOCKER_HOST=unix://$XDG_RUNTIME_DIR/podman/podman.sock
    export DOCKER_SOCK=$XDG_RUNTIME_DIR/podman/podman.sock
fi

# Setup Pnpm if available
if pnpm -v > /dev/null 2>/dev/null; then
    export PNPM_HOME="/home/dennybaa/.local/share/pnpm"
    case ":$PATH:" in
    *":$PNPM_HOME:"*) ;;
    *) export PATH="$PNPM_HOME:$PATH" ;;
    esac
fi

# Exports
export EDITOR=nvim

# Add krew
export PATH="${KREW_ROOT:-$HOME/.krew}/bin:$PATH"
