#!/bin/sh
# Don't load twice
if ( type _dot_define >/dev/null 2>/dev/null ); then return; fi
_DOT_FUNCS="_dot_define"

# Internal helper to track functions
_dot_define() {
    _DOT_FUNCS="$_DOT_FUNCS $1"
}

# Append to PATH (High Performance)
_dot_define "_dot_append_paths"
_dot_append_paths() {
    for _p in "$@"; do
        [ -d "$_p" ] || continue
        case ":$PATH:" in
            *":$_p:"*) ;; # Already there
            *) export PATH="$PATH:$_p" ;;
        esac
    done
}

# Detect Shell
_dot_define "_dot_shell"
_dot_shell() {
    if [ -n "$ZSH_VERSION" ]; then echo "zsh"
    elif [ -n "$BASH_VERSION" ]; then echo "bash"
    else echo "sh"; fi
}

# Cleanup
_dot_define "shell_cleanup"
shell_cleanup() {
    for _f in $(echo $_DOT_FUNCS); do
        unset -f "$_f"
    done
    unset _DOT_FUNCS
}

# Source file (for ~/.shell/* scripts, can specify for which shells and whether not to clean up)
_dot_define "shell_source"
shell_source() {
    _path="$1"; shift
    # Check if our shell matches
    case " $@ " in
        *" $(_dot_shell) "*) . $_path;;
        "  ") . $_path;; # any shell
    esac
    unset -v _path
}

# Load our functions for full shells
shell_source ~/.shell/functions bash zsh
