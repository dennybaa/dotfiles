#!/bin/sh
. ~/.shell/functions

# Append custom PATHS
_dot_append_paths \
    "$HOME/.local/bin" \
    "$HOME/.local/scripts"


# Use Podman instead of Docker if it is available
if (which podman >/dev/null 2>/dev/null); then
    export DOCKER_HOST=unix://$XDG_RUNTIME_DIR/podman/podman.sock
    export DOCKER_SOCK=$XDG_RUNTIME_DIR/podman/podman.sock
fi

# Default editor
export EDITOR=vim
